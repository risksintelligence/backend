# RiskSX Intelligence System (RIS) Backend Environment Configuration
# Copy this file to .env and update with your actual values

# Database & Cache
RIS_POSTGRES_DSN=postgresql://omoshola@localhost:5432/ris_database
RIS_REDIS_URL=redis://localhost:6379

# Data Provider API Keys (Replace with your actual keys)
RIS_FRED_API_KEY=your_fred_api_key_here
RIS_EIA_API_KEY=your_eia_api_key_here
RIS_CENSUS_API_KEY=your_census_api_key_here
RIS_BEA_API_KEY=your_bea_api_key_here
RIS_BLS_API_KEY=your_bls_api_key_here
RIS_ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key_here

# CORS Configuration
RIS_ALLOWED_ORIGINS=http://localhost:3000,https://ris-frontend.onrender.com

# Alert System Configuration (Optional)
ALERT_DB_URL=postgresql://user:password@localhost:5432/ris_database
ALERT_SMTP_HOST=smtp.gmail.com
ALERT_SMTP_PORT=587
ALERT_SMTP_TLS=true
ALERT_SMTP_USERNAME=your-email@gmail.com
ALERT_SMTP_PASSWORD=your-app-password
ALERT_SMTP_FROM=noreply@risksx.io
ALERT_WEBHOOK_TOKEN=

# Development Settings
DEBUG=false
LOG_LEVEL=INFO
ENVIRONMENT=development

# API Configuration
API_VERSION=v1
API_RATE_LIMIT=1000

# Security
SECRET_KEY=your-secret-key-here-change-in-production

# Render Integration (Optional - for admin console)
RENDER_API_KEY=rnd_fC2WMrcAALB2FUpwcGWwsw6ubW7e

# Cache TTL Settings (in seconds)
DEFAULT_CACHE_TTL=900
REDIS_TTL=3600
POSTGRES_TTL=86400